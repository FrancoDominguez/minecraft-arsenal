# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Secrets (curseforge_api_key, rcon_password) belong here too — they go to
# Secret Manager, never to git.

# --- Compute account ---
project_id = "my-gcp-project"
# region/zone default to Montréal (northamerica-northeast1); override if needed.

# --- Data bucket ---
bucket_name = "minecraft-arsenal-data" # must be globally unique

# For account portability, point the bucket at a permanent account you control.
# Leave empty to keep everything in project_id (self-contained — the default).
# bucket_project          = "my-permanent-project"
# bucket_credentials_file = "~/keys/permanent-sa.json"

# --- All the Mods 11 (alpha — bump these to update the pack) ---
# Find these on the ATM11 CurseForge page / API. See docs/ARCHITECTURE.md.
curseforge_project_id     = ""   # ATM11 numeric project id
curseforge_server_file_id = ""   # file id of the ServerFiles-x.x.x.zip
curseforge_api_key        = ""   # https://console.curseforge.com/ -> API Keys

# To drop back to ATM10 (stable), set these to ATM10's project/file ids and
# adjust minecraft_version / neoforge_version / java_version accordingly.

# --- Server admin ---
rcon_password = "change-me-long-random"

# --- Optional: open SSH to your IP only (otherwise use gcloud/IAP) ---
# allowed_ssh_cidrs = ["203.0.113.4/32"]
