# ============================================================================
# minecraft-arsenal — project variables (single source of truth)
#
# Copy to .env and fill in. .env is gitignored; this .example is committed so
# anyone can see every variable the project needs.
#
# Terraform reads any TF_VAR_<name> env var natively, so:
#     set -a; source .env; set +a            # load every TF_VAR_ into the env
#     terraform -chdir=terraform init
#     terraform -chdir=terraform apply
# The helper scripts in scripts/ read the same file.
#
# Use SINGLE quotes: the CurseForge API key contains '$', which the shell would
# expand (and corrupt) under double quotes when you `source .env`.
#
# List-typed vars take HCL/JSON syntax, e.g. TF_VAR_allowed_ssh_cidrs='["1.2.3.4/32"]'
# ============================================================================

# ---- Required ----
TF_VAR_project_id=''                 # GCP project that runs the VM (the compute/billing account)
TF_VAR_bucket_name=''                # globally-unique GCS bucket name, e.g. minecraft-arsenal-data
TF_VAR_rcon_password=''              # long random; used for clean backups (-> Secret Manager)

# ---- CurseForge / All the Mods 10 ----
TF_VAR_curseforge_api_key=''             # from https://console.curseforge.com/ (-> Secret Manager)
TF_VAR_curseforge_project_id='925200'    # ATM10 numeric project id  (run: python3 scripts/find-atm-server-file.py all-the-mods-10)
TF_VAR_curseforge_server_file_id='8323948'  # ATM10 ServerFiles zip file id (8323948 = ServerFiles-7.1, newest as of 2026-06-28)

# ---- Pack/runtime versions (bump for ATM10 updates) ----
TF_VAR_minecraft_version='1.21.1'
TF_VAR_neoforge_version='21.1.180'
TF_VAR_java_version='21'
TF_VAR_jvm_heap='12G'

# ---- Compute (optional — sensible defaults in variables.tf) ----
TF_VAR_region='northamerica-northeast1'      # Montréal
TF_VAR_zone='northamerica-northeast1-a'
TF_VAR_machine_type='e2-standard-4'          # bump to e2-standard-8 if laggy
# TF_VAR_credentials_file=''                 # path to compute SA key; empty = gcloud ADC

# ---- Data bucket portability (optional) ----
# Point the bucket at a PERMANENT account so data outlives any compute account.
# TF_VAR_bucket_project=''
# TF_VAR_bucket_region=''
# TF_VAR_bucket_credentials_file=''
# TF_VAR_backup_retention_days='14'

# ---- Networking (optional) ----
TF_VAR_server_port='25565'
# TF_VAR_allowed_ssh_cidrs='["203.0.113.4/32"]'   # empty/unset = no public SSH (use gcloud/IAP)
# TF_VAR_allowed_player_cidrs='["0.0.0.0/0"]'      # game port public; whitelist controls joins
